---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <section class="section">
    <article class="container" style="max-width:760px;line-height:1.85;">
      <a href="/blog" class="accent-link" style="font-size:0.88rem;margin-bottom:1.5rem;display:inline-flex;">&larr; Back to blog</a>
      <h1 style="font-size:clamp(1.8rem,4vw,2.4rem);font-weight:800;letter-spacing:-0.02em;margin-bottom:0.4rem;">{post.data.title}</h1>
      <p style="color:var(--text-muted);font-size:0.88rem;margin-bottom:2rem;">{post.data.pubDate.toDateString()}</p>
      <div style="color:var(--text-muted);font-size:1.02rem;">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
