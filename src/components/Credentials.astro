---
import { certifications } from "../data/certifications";
import { community, galleryPhotos } from "../data/community";
import { socials } from "../data/socials";
---

<section class="section">
  <div class="container">
    <div class="fade-in">
      <p class="section-label">Credentials & Recognition</p>
      <h2 class="section-title">Always learning, always contributing</h2>
    </div>

    <div class="gallery fade-in">
      {galleryPhotos.map((photo) => (
        <div class="gallery-item">
          <img src={photo.src} alt={photo.caption} loading="lazy" class="gallery-img" />
          <div class="gallery-caption">{photo.caption}</div>
        </div>
      ))}
    </div>

    <div class="featured-video fade-in">
      <h3 class="cred-heading">MTronic product release</h3>
      <p class="video-caption">A look at the IoT home automation product release from my time leading the software team at MTronic.</p>
      <div class="video-wrap glass">
        <video class="video-player" src="/videos/mtronic-release.mp4" controls preload="metadata" poster="">
          Your browser does not support the video tag.
        </video>
      </div>
      <p class="video-credit">
        Video by <a href="https://www.linkedin.com/in/umerfarooqai/" target="_blank" rel="noreferrer" class="accent-link">Umer Farooq</a>, CTO at MTronic.
      </p>
    </div>

    <div class="cred-grid fade-in">
      <div class="cred-certs">
        <h3 class="cred-heading">Certifications</h3>
        {certifications.map((c) => (
          <div class="glass cert-group">
            <h4 class="cert-group-title">{c.group}</h4>
            <ul class="cert-list">
              {c.items.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
        <p class="cert-tagline">
          15+ certifications across architecture, cloud, ML, and leadership.
          <a href={socials.linkedin} target="_blank" rel="noreferrer" class="accent-link">View all on LinkedIn &rarr;</a>
        </p>
      </div>

      <div class="cred-community">
        <h3 class="cred-heading">Community</h3>
        <p class="community-subtitle">Invited as a technical judge at national-level university competitions and industry awards.</p>
        <div class="community-list">
          {community.map((item) => (
            <div class="community-item">
              <span class="community-name">{item.title}</span>
              <span class="community-meta">{item.org} &middot; {item.years}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
    margin-bottom: 3rem;
  }
  .gallery-item {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    cursor: pointer;
  }
  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .gallery-item:hover .gallery-img {
    transform: scale(1.05);
  }
  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.7rem 0.8rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    color: #fff;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.4;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .gallery-item:hover .gallery-caption {
    opacity: 1;
  }
  .cred-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .cred-heading {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }
  .cert-group {
    padding: 1rem 1.1rem;
    margin-bottom: 0.6rem;
  }
  .cert-group-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }
  .cert-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
  .cert-list li {
    padding: 0.2rem 0;
    padding-left: 1rem;
    position: relative;
  }
  .cert-list li::before {
    content: "\2022";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .cert-tagline {
    font-size: 0.86rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .community-subtitle {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-bottom: 0.8rem;
    line-height: 1.6;
  }
  .community-list {
    display: grid;
    gap: 0.5rem;
  }
  .community-item {
    display: flex;
    flex-direction: column;
    padding: 0.7rem 0.9rem;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  .community-item:hover {
    border-color: var(--accent);
  }
  .community-name {
    font-weight: 600;
    font-size: 0.9rem;
  }
  .community-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .featured-video {
    margin-bottom: 2.5rem;
  }
  .featured-video .cred-heading {
    margin-bottom: 0.35rem;
  }
  .video-caption {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.9rem;
    line-height: 1.55;
  }
  .video-wrap {
    border-radius: 14px;
    overflow: hidden;
    padding: 0.25rem;
    max-width: 720px;
  }
  .video-player {
    width: 100%;
    display: block;
    border-radius: 10px;
    background: #000;
  }
  .video-credit {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
    margin-bottom: 0;
  }
  @media (max-width: 768px) {
    .gallery { grid-template-columns: repeat(2, 1fr); }
    .cred-grid { grid-template-columns: 1fr; }
  }
</style>
