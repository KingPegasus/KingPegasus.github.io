---
const { project } = Astro.props;
---

<article class="glass project-card">
  {project.data.image && (
    <div class="project-image-wrap">
      <img src={project.data.image} alt={`${project.data.title} screenshot`} class="project-image" loading="lazy" />
    </div>
  )}
  <div class="project-number">{String(project.data.order).padStart(2, '0')}</div>
  <h3 class="project-title">{project.data.title}</h3>
  <p class="project-summary">{project.data.summary}</p>
  {project.data.url && (
    <a href={project.data.url} target="_blank" rel="noreferrer" class="accent-link project-link">
      Visit project &rarr;
    </a>
  )}
  <div class="project-tags">
    {project.data.tags.map((tag: string) => <span class="chip">{tag}</span>)}
  </div>
</article>

<style>
  .project-card {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
    overflow: hidden;
  }
  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), #9333ea);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .project-card:hover::before {
    opacity: 1;
  }
  .project-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent);
    font-weight: 500;
  }
  .project-image-wrap {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 0.2rem;
    border: 1px solid var(--border);
    background: var(--surface);
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
  }
  .project-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
  }
  .project-title {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .project-summary {
    font-size: 0.92rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
  .project-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
  .project-link {
    font-size: 0.88rem;
    margin-top: 0.25rem;
    margin-bottom: 0.1rem;
  }
</style>
